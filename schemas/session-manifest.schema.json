{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "session-manifest.schema.json",
  "title": "Codex Agent resumable session manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "id",
    "resumable",
    "status",
    "revision",
    "createdAt",
    "updatedAt",
    "git",
    "handoff",
    "selectedContext",
    "artifacts",
    "candidates"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{7,79}$" },
    "resumable": { "const": true },
    "status": { "enum": ["active", "paused", "completed", "abandoned"] },
    "revision": { "type": "integer", "minimum": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "required": ["branch", "head", "worktreeHash"],
      "properties": {
        "branch": { "type": ["string", "null"] },
        "head": { "type": ["string", "null"], "pattern": "^[0-9a-f]{40}$" },
        "worktreeHash": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "const": "handoff.md" },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "selectedContext": {
      "type": "array",
      "maxItems": 50,
      "items": { "$ref": "#/$defs/fileDigest" }
    },
    "artifacts": {
      "type": "array",
      "maxItems": 200,
      "items": { "$ref": "#/$defs/optionalFileDigest" }
    },
    "candidates": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "sha256", "status"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,79}$" },
          "path": { "type": "string", "pattern": "^candidates/[a-z0-9][a-z0-9-]{2,79}\\.md$", "maxLength": 500 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "status": { "enum": ["proposed", "accepted", "rejected", "promoted", "superseded"] }
        }
      }
    }
  },
  "$defs": {
    "fileDigest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "pattern": "^(?!/)(?!.*\\.\\./)(?!.*\\\\).+", "maxLength": 500 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "optionalFileDigest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "pattern": "^(?!/)(?!.*\\.\\./)(?!.*\\\\).+", "maxLength": 500 },
        "sha256": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" }
      }
    }
  }
}
