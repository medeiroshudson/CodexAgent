{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "context-candidate.schema.json",
  "title": "Codex Agent temporary context candidate metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "id",
    "sourceSessionId",
    "createdAt",
    "title",
    "kind",
    "summary",
    "scope",
    "evidence",
    "tags",
    "priority",
    "confidence"
  ],
  "properties": {
    "version": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,79}$" },
    "sourceSessionId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{7,79}$" },
    "createdAt": { "type": "string", "format": "date-time" },
    "title": { "type": "string", "minLength": 5, "maxLength": 100 },
    "kind": { "enum": ["decision", "constraint", "operation", "domain", "pitfall"] },
    "summary": { "type": "string", "minLength": 10, "maxLength": 240 },
    "scope": { "type": "string", "minLength": 2, "maxLength": 120 },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "note"],
        "properties": {
          "path": { "type": "string", "pattern": "^(?!/)(?!.*\\.\\./)(?!.*\\\\).+", "maxLength": 300 },
          "note": { "type": "string", "minLength": 5, "maxLength": 300 }
        }
      }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z0-9]+(?:[_-][a-z0-9]+)*$" }
    },
    "priority": { "enum": ["critical", "high", "medium", "low"] },
    "confidence": { "enum": ["high", "medium"] },
    "reviewWhen": {
      "type": "array",
      "maxItems": 5,
      "items": { "type": "string", "minLength": 5, "maxLength": 240 }
    }
  }
}
