{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "context-proposal.schema.json",
  "title": "Codex Agent durable context proposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version", "title", "kind", "summary", "scope", "contentMarkdown",
    "evidence", "tags", "priority", "confidence"
  ],
  "properties": {
    "version": { "const": 1 },
    "title": { "type": "string", "minLength": 5, "maxLength": 100 },
    "kind": { "enum": ["decision", "constraint", "operation", "domain", "pitfall"] },
    "summary": { "type": "string", "minLength": 10, "maxLength": 240 },
    "scope": { "type": "string", "minLength": 2, "maxLength": 120 },
    "contentMarkdown": { "type": "string", "minLength": 20, "maxLength": 10000 },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "note"],
        "properties": {
          "path": { "type": "string", "minLength": 1, "maxLength": 300 },
          "note": { "type": "string", "minLength": 5, "maxLength": 300 }
        }
      }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z0-9]+(?:[_-][a-z0-9]+)*$" }
    },
    "priority": { "enum": ["critical", "high", "medium", "low"] },
    "confidence": { "enum": ["high", "medium"] },
    "reviewWhen": {
      "type": "array",
      "maxItems": 5,
      "items": { "type": "string", "minLength": 5, "maxLength": 240 }
    }
  }
}
